# Copy to .env and paste your key. Uses the SAME NVIDIA build (NIM) key as the CRAG project.
NVIDIA_API_KEY=

# --- Where the copilot reads YOUR experience docs and stores the index ---
# These drive the reused crag engine. Defaults point inside this project.
EXP_CORPUS_DIR=data/corpus
EXP_PERSIST_DIR=chroma_store

# How many relevant chunks before we consider a question "covered" by your KB.
# Keep low (1) for a small personal corpus.
EXP_RELEVANCE_THRESHOLD=1

# Models inherit the crag defaults (meta/llama-3.3-70b-instruct, nvidia/nv-embedqa-e5-v5).
