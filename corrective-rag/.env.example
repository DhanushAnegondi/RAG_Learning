# Copy this file to .env and paste your key. This project uses NVIDIA build (NIM) endpoints.

# --- LLM + embeddings: NVIDIA NIM (the only key you need) ---
# Get a key at https://build.nvidia.com  -> generate an API key (starts with "nvapi-").
NVIDIA_API_KEY=

# --- Model ids (override only if you know why; defaults are verified-live on build.nvidia.com) ---
CRAG_LLM_MODEL=meta/llama-3.3-70b-instruct
CRAG_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# --- Retrieval / grading knobs (sensible defaults; see docs/rules/rag-best-practices.md) ---
CRAG_TOP_K=4
CRAG_RELEVANCE_THRESHOLD=2          # >= this many relevant chunks => skip the correction path

# --- Web-search fallback (M4) uses duckduckgo-search; no key required. ---

# Note: no OPENAI / ANTHROPIC / TAVILY keys are used anywhere in this project.
